generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

enum Role {
    USER
    ADMIN
}

model User {
    id        String   @id @default(uuid()) @db.Uuid
    role      Role     @default(USER)
    name      String   @db.VarChar(255)
    email     String   @unique
    password  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
